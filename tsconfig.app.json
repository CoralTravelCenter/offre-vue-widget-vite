{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "app/*": [
        "src/app/*"
      ],
      "brands/*": [
        "src/brands/*"
      ],
      "components/*": [
        "src/shared/components/*"
      ],
      "composables/*": [
        "src/app/composables/*"
      ],
      "dev/*": [
        "src/dev/*"
      ],
      "directives/*": [
        "src/directives/*"
      ],
      "lib/*": [
        "src/shared/lib/*"
      ],
      "monkey/*": [
        "src/monkey/*"
      ],
      "offre/*": [
        "src/offre/*"
      ],
      "shared/*": [
        "src/shared/*"
      ],
      "styles/*": [
        "src/styles/*"
      ],
      "ui/*": [
        "src/shared/components/ui/*"
      ],
      "utils": [
        "src/shared/lib/utils.ts"
      ],
      "widget/*": [
        "src/widget/*"
      ]
    },
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src/env.d.ts"
  ]
}
