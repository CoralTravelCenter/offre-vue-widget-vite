{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "app/*": [
        "src/app/*"
      ],
      "brands/*": [
        "src/brands/*"
      ],
      "dev/*": [
        "src/dev/*"
      ],
      "directives/*": [
        "src/directives/*"
      ],
      "monkey/*": [
        "src/monkey/*"
      ],
      "offre/*": [
        "src/offre/*"
      ],
      "shared/*": [
        "src/shared/*"
      ],
      "styles/*": [
        "src/styles/*"
      ],
      "ui/*": [
        "src/shared/components/ui/*"
      ],
      "widget/*": [
        "src/widget/*"
      ]
    }
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
